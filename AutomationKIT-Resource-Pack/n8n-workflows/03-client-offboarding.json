      "parameters": {
        "conditions": { "options": { "caseSensitive": true, "typeValidation": "loose" }, "conditions": [ { "id": "c1", "leftValue": "={{ $('Parse Offboard Payload').item.json.projectPageId }}", "rightValue": "", "operator": { "type": "string", "operation": "notEmpty" } } ], "combinator": "and" },
        "options": {}
      },
