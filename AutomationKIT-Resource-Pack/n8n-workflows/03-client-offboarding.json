      "id": "wh-offboard-01", "name": "Webhook - Offboard Client", "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [-680, 0], "webhookId": "offboard-client-demo"
    },
    {
      "parameters": {
        "jsCode": "// Parses Notion's button webhook payload (or simple/query fallback).\nconst body = $json.body || {};\nconst query = $json.query || {};\nconst data = body.data || body;\nconst props = (data && data.properties) ? data.properties : {};\nfunction extract(p){ if(p==null) return ''; if(typeof p==='string'||typeof p==='number') return String(p); if(Array.isArray(p)) return p.map(x=>(x&&(x.plain_text||(x.text&&x.text.content)))||'').join(''); const t=p.type; if(t==='title'||t==='rich_text'){const a=p[t]||[];return a.map(x=>x.plain_text||'').join('');} if(t==='email') return p.email||''; if(t==='select') return p.select?p.select.name:''; return ''; }\nfunction field(names){ for(const n of names){ if(props&&props[n]!=null){const v=extract(props[n]); if(v) return v;} if(body&&body[n]!=null&&typeof body[n]!=='object') return String(body[n]); if(query&&query[n]!=null) return String(query[n]); } return ''; }\nconst clientPageId = (data&&data.id)||body.id||body.client_page_id||query.client_page_id||'';\nconst projectPageId = (props.Projects&&props.Projects.relation&&props.Projects.relation[0]&&props.Projects.relation[0].id) || body.project_id || query.project_id || '';\nreturn [{ json: { clientPageId, projectPageId, companyName: field(['Company','company']), contactName: field(['Name','name','contact_name']), contactEmail: field(['Email','email','contact_email']) } }];"
      },
      "id": "set-offb-01", "name": "Parse Offboard Payload", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [-460, 0]
    },
    {
      "parameters": {
        "resource": "databasePage", "operation": "update",
        "pageId": { "__rl": true, "value": "={{ $('Parse Offboard Payload').item.json.clientPageId }}", "mode": "id" },
        "propertiesUi": { "propertyValues": [ { "key": "Status|select", "selectValue": "⭐ Alumni" } ] }
      },
      "id": "notion-alumni-01", "name": "Set Client Alumni", "type": "n8n-nodes-base.notion", "typeVersion": 2.2, "position": [-240, 0],
      "credentials": { "notionApi": { "id": "", "name": "Notion account" } }
    },
    {
      "parameters": {
        "fromEmail": "you@yourdomain.com",
        "toEmail": "={{ $('Parse Offboard Payload').item.json.contactEmail }}",
        "subject": "=Thank you, {{ $('Parse Offboard Payload').item.json.contactName.split(' ')[0] }}!",
        "emailFormat": "text",
        "text": "=Hi {{ $('Parse Offboard Payload').item.json.contactName }},\n\nThank you for trusting us with {{ $('Parse Offboard Payload').item.json.companyName }} — it's been a pleasure. Your project is wrapped up and complete on our end.\n\n• We'll send a short recap and any final assets\n• If we delivered value, a testimonial or referral means the world\n• The door is always open — reach out anytime\n\nWishing you continued success,\nThe Team",
        "options": {}
      },
      "id": "smtp-wrap-01", "name": "Send Wrap-up Email", "type": "n8n-nodes-base.emailSend", "typeVersion": 2.1, "position": [-20, -150],
      "credentials": { "smtp": { "id": "", "name": "SMTP account" } }
    },
    {
      "parameters": { "respondWith": "json", "responseBody": "={{ { \"status\": \"offboarded\" } }}", "options": {} },
